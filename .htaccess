SetEnv BOT_TOKEN ""
SetEnv WEBHOOK_URL ""
SetEnv WEBHOOK_SECRET ""
SetEnv ADMIN_PASSWORD "changeme"
# SetEnv REFERRAL_PERCENT 5

Options -Indexes

<FilesMatch "^(config|helpers)\.php$">
    Require all denied
</FilesMatch>

<FilesMatch "\.(json|lock)$">
    Require all denied
</FilesMatch>

<Files "webhook.php">
    <If "%{REQUEST_METHOD} != 'POST'">
        Require all denied
    </If>
</Files>
