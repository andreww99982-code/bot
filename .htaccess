# .htaccess — Security rules for the bot root directory

# Deny direct browser access to sensitive PHP files
<FilesMatch "^(config|helpers|set_webhook)\.php$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Explicitly allow POST requests to webhook endpoint
<Files "webhook.php">
    <Limit POST>
        Order allow,deny
        Allow from all
    </Limit>
</Files>

# Prevent directory listings
Options -Indexes

# Hide server signature
ServerSignature Off
