# .htaccess — Security rules for the bot root directory

# Deny direct browser access to sensitive PHP files
<FilesMatch "^(config|helpers|set_webhook)\.php$">
    Order deny,allow
    Deny from all
</FilesMatch>

# Prevent directory listings
Options -Indexes

# Hide server signature
ServerSignature Off

# Deny direct access to the data directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^data/.*$ - [F,L]
    RewriteRule ^storage/.*$ - [F,L]
</IfModule>
